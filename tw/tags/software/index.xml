    <item>
      <title>VSCode</title>
      <link>http://localhost:1313/tw/doc/software/vscode/</link>
      <pubDate>Wed, 06 Mar 2024 00:00:00 +0800</pubDate>
      
      <guid>http://localhost:1313/tw/doc/software/vscode/</guid>
      <description>
        
          
            &lt;h2 id=&#34;style&#34;&gt;Style&lt;/h2&gt;
&lt;p&gt;&lt;a href=&#34;https://marketplace.visualstudio.com/items?itemName=file-icons.file-icons&#34;&gt;file-icons&lt;/a&gt;
&lt;a href=&#34;https://marketplace.visualstudio.com/items?itemName=PKief.material-icon-theme&#34;&gt;Material Icon Theme&lt;/a&gt;&lt;/p&gt;
&lt;h2 id=&#34;test-related&#34;&gt;Test related&lt;/h2&gt;
&lt;h3 id=&#34;coverage-gutters&#34;&gt;&lt;a href=&#34;https://marketplace.visualstudio.com/items?itemName=ryanluker.vscode-coverage-gutters&#34;&gt;Coverage Gutters&lt;/a&gt;&lt;/h3&gt;
&lt;ul&gt;
&lt;li&gt;Ctrl-Shift-6: Generate a HTML report.&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;settings.json&lt;/p&gt;
&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-fallback&#34; data-lang=&#34;fallback&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;1&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;&amp;#34;coverage-gutters.showLineCoverage&amp;#34;: false,
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;2&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;&amp;#34;coverage-gutters.showGutterCoverage&amp;#34;: false,
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h2 id=&#34;formatter&#34;&gt;Formatter&lt;/h2&gt;
&lt;h3 id=&#34;isort&#34;&gt;&lt;a href=&#34;https://marketplace.visualstudio.com/items?itemName=ms-python.isort&#34;&gt;isort&lt;/a&gt;&lt;/h3&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Parameter&lt;/th&gt;
					&lt;th&gt;Purpose&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;--line-length=150&lt;/td&gt;
					&lt;td&gt;Change the line width to 150 chars.&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;isort.check: true&lt;/td&gt;
					&lt;td&gt;Enable the check.&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-fallback&#34; data-lang=&#34;fallback&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;1&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;&amp;#34;isort.args&amp;#34;: [
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;2&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;        &amp;#34;--line-length=150&amp;#34;,
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;3&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;    ],
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;4&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;    &amp;#34;isort.check&amp;#34;: true,
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h3 id=&#34;black-formatter&#34;&gt;&lt;a href=&#34;https://marketplace.visualstudio.com/items?itemName=ms-python.black-formatter&#34;&gt;Black Formatter&lt;/a&gt;&lt;/h3&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Parameter&lt;/th&gt;
					&lt;th&gt;Purpose&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;--line-length=150&lt;/td&gt;
					&lt;td&gt;Change the line width to 150 chars.&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;--skip-string-normalization&lt;/td&gt;
					&lt;td&gt;Disables Black&#39;s conversion of string delimiters, e.g. it will NOT convert single quote to double quote.&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-fallback&#34; data-lang=&#34;fallback&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;1&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;&amp;#34;black-formatter.args&amp;#34;: [
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;2&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;        &amp;#34;--line-length=150&amp;#34;,
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;3&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;        &amp;#34;--skip-string-normalization&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;4&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;    ],
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h3 id=&#34;editor&#34;&gt;Editor&lt;/h3&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Parameter&lt;/th&gt;
					&lt;th&gt;Purpose&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;editor.formatOnPaste&lt;/td&gt;
					&lt;td&gt;Automatically format the line afer paste&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;editor.formatOnSave&lt;/td&gt;
					&lt;td&gt;Automatically format the line afer save&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;editor.formatOnType&lt;/td&gt;
					&lt;td&gt;Automatically format the line afer typing&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-fallback&#34; data-lang=&#34;fallback&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;1&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;&amp;#34;editor.formatOnPaste&amp;#34;: true,
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;2&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;&amp;#34;editor.formatOnSave&amp;#34;: true,
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;3&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;&amp;#34;editor.formatOnType&amp;#34;: true,
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h3 id=&#34;python&#34;&gt;Python&lt;/h3&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Parameter&lt;/th&gt;
					&lt;th&gt;Purpose&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;editor.defaultFormatter&lt;/td&gt;
					&lt;td&gt;Assign the default formatter&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;source.organizeImports&lt;/td&gt;
					&lt;td&gt;Execute isort when save&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-fallback&#34; data-lang=&#34;fallback&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;1&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;&amp;#34;[python]&amp;#34;: {
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;2&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;    &amp;#34;editor.defaultFormatter&amp;#34;: &amp;#34;ms-python.black-formatter&amp;#34;,
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;3&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;    &amp;#34;editor.codeActionsOnSave&amp;#34;: {
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;4&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;        &amp;#34;source.organizeImports&amp;#34;: true
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;5&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;    },
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;6&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;    &amp;#34;diffEditor.ignoreTrimWhitespace&amp;#34;: false,
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;7&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;    &amp;#34;editor.wordBasedSuggestions&amp;#34;: false
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;8&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;}
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;
          
          
        
      </description>
    </item>
    
    <item>
      <title>如何在 XnView MP 中添加照片 GPS 信息</title>
      <link>http://localhost:1313/tw/doc/software/xnview-how-to-add-gps-info/</link>
      <pubDate>Fri, 31 Mar 2023 00:00:00 +0800</pubDate>
      
      <guid>http://localhost:1313/tw/doc/software/xnview-how-to-add-gps-info/</guid>
      <description>
        
          
            &lt;h2 id=&#34;需求&#34;&gt;需求&lt;/h2&gt;
&lt;p&gt;用相機拍的照片, 一般來講不會有 GPS 資訊, 得手動設定, 需要這些功能&lt;/p&gt;
&lt;ol&gt;
&lt;li&gt;支援 Google Maps&lt;/li&gt;
&lt;li&gt;支援一次寫入多張&lt;/li&gt;
&lt;li&gt;盡量不要用 &lt;a href=&#34;https://exiftool.org/&#34;&gt;ExifTool&lt;/a&gt;, 因為檔案一多, 呼叫外部程式一張一張改要很久.&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id=&#34;使用-xnview-mp-編輯-gps-資訊&#34;&gt;使用 XnView MP 編輯 GPS 資訊&lt;/h2&gt;
&lt;p&gt;&lt;a href=&#34;https://www.xnview.com/en/xnviewmp/&#34;&gt;XnView MP&lt;/a&gt; 是老牌影像軟體了, 依下列步驟可編輯 GPS 資訊&lt;/p&gt;
&lt;ol&gt;
&lt;li&gt;
&lt;p&gt;使用 Google Maps 找到你的位置, 並對著經緯度按左鍵, 他就會把經位度複製到剪貼簿 (實際內容類似 25.171603204182567, 121.55359931326444)&lt;/p&gt;
&lt;figure&gt;&lt;img src=&#34;http://localhost:1313/images/software/software/google-map-copy-gps-data.webp&#34; width=&#34;350&#34;&gt;
    &lt;/figure&gt;

&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;執行 XnView MP&lt;/p&gt;
&lt;ol&gt;
&lt;li&gt;選好照片 (單張或多張)&lt;/li&gt;
&lt;li&gt;執行 Menu -&amp;gt; Tools -&amp;gt; Metadata -&amp;gt; edit GPS&lt;/li&gt;
&lt;li&gt;按下 Paste, 就會看到經緯度貼上來了. 記得要按 Write(單張)或 Write all(多張), 他才會真的寫入檔案.
&lt;figure&gt;&lt;img src=&#34;http://localhost:1313/images/software/software/xnview-edit-gps-data.webp&#34; width=&#34;553&#34;&gt;
    &lt;/figure&gt;
&lt;/li&gt;
&lt;li&gt;如果你還要編輯地點,國家,城市等等, 有兩個地方可以修改
&lt;ol&gt;
&lt;li&gt;若要放在 IPTC, 則執行 Menu -&amp;gt; Tools -&amp;gt; Metadata -&amp;gt; edit IPTC..., 然後選 Source tab
&lt;figure&gt;&lt;img src=&#34;http://localhost:1313/images/software/software/xnview-edit-iptc.webp&#34; width=&#34;528&#34;&gt;
        &lt;/figure&gt;
&lt;/li&gt;
&lt;li&gt;若要放在 XMP, 則執行 Menu -&amp;gt; Tools -&amp;gt; Metadata -&amp;gt; edit XMP..., 然後選 Origin tab
&lt;figure&gt;&lt;img src=&#34;http://localhost:1313/images/software/software/xnview-edit-xmp.webp&#34; width=&#34;528&#34;&gt;
        &lt;/figure&gt;
&lt;/li&gt;
&lt;/ol&gt;
&lt;/li&gt;
&lt;li&gt;編輯完後請記得要 Write (or Write all)&lt;/li&gt;
&lt;/ol&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;存檔完後, 在 XnView 的 Info 視窗裡面的 GPS, Exif, IPTC-IIM, XMP 這幾個 tab 都會有相關資訊&lt;/p&gt;
          
          
        
      </description>
    </item>
    
    <item>
      <title>Double Commander (檔案總管替代工具)</title>
      <link>http://localhost:1313/tw/doc/software/double-commander/</link>
      <pubDate>Fri, 27 Jan 2023 10:18:32 +0800</pubDate>
      
      <guid>http://localhost:1313/tw/doc/software/double-commander/</guid>
      <description>
        
          
            &lt;p&gt;&lt;a href=&#34;https://doublecmd.sourceforge.io/&#34;&gt;Double Commander&lt;/a&gt; 是個好用的跨平台 open source 的 file manager (設計理念接近 &lt;a href=&#34;https://www.ghisler.com/&#34;&gt;Total Commander&lt;/a&gt;),  他可以調整的設定很多, 把他調得順手了, 順便做個紀錄.&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;GitHub: &lt;a href=&#34;https://github.com/doublecmd/doublecmd&#34;&gt;https://github.com/doublecmd/doublecmd&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;Download: &lt;a href=&#34;https://sourceforge.net/p/doublecmd/wiki/Download/&#34;&gt;https://sourceforge.net/p/doublecmd/wiki/Download/&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id=&#34;設定&#34;&gt;設定&lt;/h2&gt;
&lt;ol&gt;
&lt;li&gt;
&lt;p&gt;Directory Hotlist&lt;/p&gt;
&lt;ol&gt;
&lt;li&gt;這個很好用, 在 double commander 裡面按 ctrl-d, 就可以快速切換預先定義好的目錄.&lt;/li&gt;
&lt;li&gt;建議是把目錄還要加上 hotkey, 譬如這裡我就可以按 ctrl-d -&amp;gt; D, 他就會跳到 &lt;strong&gt;下載&lt;/strong&gt; 目錄, 很方便.
&lt;figure&gt;&lt;img src=&#34;http://localhost:1313/images/software/double_commander/doublecmd_directory_hotlist.webp&#34; width=&#34;800&#34;&gt;
    &lt;/figure&gt;
&lt;/li&gt;
&lt;/ol&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;File associations&lt;/p&gt;
&lt;p&gt;這個是用來設定在檔案按下右鍵的時候, &lt;em&gt;Actions&lt;/em&gt; 裡面會出現的指令, 預設是只有 &lt;em&gt;View&lt;/em&gt; 和 &lt;em&gt;Edit&lt;/em&gt;.
如果我要在 &lt;em&gt;Actions&lt;/em&gt; 裡面加上一個 &lt;em&gt;Convert to WebP&lt;/em&gt; 的功能 (使用 &lt;a href=&#34;https://imagemagick.org/&#34;&gt;ImageMagick&lt;/a&gt; ), 方法如下:&lt;/p&gt;
&lt;ol&gt;
&lt;li&gt;將轉檔程式放在 &lt;em&gt;d:\bin\image\imagemagick\convert.exe&lt;/em&gt;&lt;/li&gt;
&lt;li&gt;File types, Icon, Actions name 請自行輸入喜歡的名字.&lt;/li&gt;
&lt;li&gt;Extensions 請輸入你要對應的檔案副檔名.&lt;/li&gt;
&lt;li&gt;Command 就輸入 ImageMagick 裡面的 convert.exe 的完整路徑.&lt;/li&gt;
&lt;li&gt;Parameters: 我是用 &lt;em&gt;%&amp;quot;0&amp;quot;%f&amp;quot; %&amp;quot;0&amp;quot;%o.webp&amp;quot;&lt;/em&gt;, 因為 ImageMagick 是認檔案名稱來決定轉檔格式, 所以這裡直接寫檔名就好. 變數的部分可參考 &lt;a href=&#34;https://doublecmd.github.io/doc/en/variables.html&#34;&gt;https://doublecmd.github.io/doc/en/variables.html&lt;/a&gt;.
這邊請 &lt;a href=&#34;https://doublecmd.github.io/doc/en/variables.html#quotation&#34;&gt;&lt;em&gt;&lt;strong&gt;特別注意雙引號的問題&lt;/strong&gt;&lt;/em&gt;&lt;/a&gt; .&lt;/li&gt;
&lt;li&gt;Start path 預設就會是執行的目錄, 所以我這邊不填
&lt;figure&gt;&lt;img src=&#34;http://localhost:1313/images/software/double_commander/doublecmd_file_associations.webp&#34; width=&#34;700&#34;&gt;
    &lt;/figure&gt;
&lt;/li&gt;
&lt;li&gt;如果跑出來不如預期, 可以從 Layout 打開 &lt;em&gt;Show log window&lt;/em&gt;, 看他實際執行的指令
&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-cmd&#34; data-lang=&#34;cmd&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;1&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;Launch external: Filename=d:\bin\image\imagemagick\convert / Param=&lt;span class=&#34;s2&#34;&gt;&amp;#34;P20220310.JPG&amp;#34;&lt;/span&gt; &lt;span class=&#34;s2&#34;&gt;&amp;#34;P20220310.webp&amp;#34;&lt;/span&gt; / WorkDir=C:\temp\
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;2&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;Result external: Result=Success! / Filename=d:\bin\image\imagemagick\convert / Param=&lt;span class=&#34;s2&#34;&gt;&amp;#34;P20220310.JPG&amp;#34;&lt;/span&gt; &lt;span class=&#34;s2&#34;&gt;&amp;#34;P20220310.webp&amp;#34;&lt;/span&gt; / WorkDir=C:\temp\
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/li&gt;
&lt;li&gt;&lt;em&gt;&lt;strong&gt;注意&lt;/strong&gt;&lt;/em&gt;: 他只能一次處理一個檔案, 如果給他兩個, 他會把檔案名稱串在一起去執行, 變成如下, 這樣當然就跑不出來.
&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-cmd&#34; data-lang=&#34;cmd&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;1&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;Launch external: Filename=d:\bin\image\imagemagick\convert / Param=&lt;span class=&#34;s2&#34;&gt;&amp;#34;File1.JPG File2.JPG&amp;#34;&lt;/span&gt; &lt;span class=&#34;s2&#34;&gt;&amp;#34;File1 File2.webp&amp;#34;&lt;/span&gt; / WorkDir=C:\temp\ 
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/li&gt;
&lt;/ol&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;File operations&lt;/p&gt;
          
          
        
      </description>
    </item>
    
    <item>
      <title>FreeCommander (檔案總管替代工具)</title>
      <link>http://localhost:1313/tw/doc/software/free-commander/</link>
      <pubDate>Fri, 27 Jan 2023 10:18:32 +0800</pubDate>
      
      <guid>http://localhost:1313/tw/doc/software/free-commander/</guid>
      <description>
        
          
            &lt;p&gt;&lt;a href=&#34;https://freecommander.com/&#34;&gt;FreeCommander&lt;/a&gt; 是個好用的跨平台 open source 的 file manager (設計理念接近 &lt;a href=&#34;https://www.ghisler.com/&#34;&gt;Total Commander&lt;/a&gt;),  他可以調整的設定很多, 把他調得順手了, 順便做個紀錄.&lt;/p&gt;
&lt;h2 id=&#34;設定&#34;&gt;設定&lt;/h2&gt;
&lt;ol&gt;
&lt;li&gt;Tools -&amp;gt; Define action toolsbars: 把 splitter 取消, 就可以關掉中間那條 toolbar.&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id=&#34;不順手的地方&#34;&gt;不順手的地方&lt;/h2&gt;
&lt;ol&gt;
&lt;li&gt;暫時沒有&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id=&#34;其他&#34;&gt;其他&lt;/h2&gt;
&lt;ol&gt;
&lt;li&gt;64 bit 是要錢的&lt;/li&gt;
&lt;li&gt;更版沒有很頻繁, 大概一年一版&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id=&#34;和其他類似軟體的比較&#34;&gt;和其他類似軟體的比較&lt;/h2&gt;
&lt;p&gt;類似的軟體很多, 功能都有些許接近和重複, 挑喜歡的就好.&lt;/p&gt;
&lt;ol&gt;
&lt;li&gt;&lt;a href=&#34;https://freecommander.com/en/summary/&#34;&gt;FreeCommander&lt;/a&gt;, &lt;a href=&#34;http://multicommander.com/&#34;&gt;MultiCommander&lt;/a&gt;: 這兩個是免費的.&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;http://www.q-dir.com/&#34;&gt;Q-Dir&lt;/a&gt;: 這個也是免費的, 小巧, 可以開 4 個 panel.&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;https://www.ghisler.com/&#34;&gt;Total Commander&lt;/a&gt;, &lt;a href=&#34;https://www.xyplorer.com/&#34;&gt;XYplorer&lt;/a&gt;: 這兩個是要付錢的.&lt;/li&gt;
&lt;/ol&gt;
          
          
        
      </description>
    </item>
    
    <item>
      <title>Multi Commander (檔案總管替代工具)</title>
      <link>http://localhost:1313/tw/doc/software/multi-commander/</link>
      <pubDate>Fri, 27 Jan 2023 10:18:32 +0800</pubDate>
      
      <guid>http://localhost:1313/tw/doc/software/multi-commander/</guid>
      <description>
        
          
            &lt;p&gt;&lt;a href=&#34;http://multicommander.com/&#34;&gt;Multi Commander&lt;/a&gt; 是個好用的跨平台 open source 的 file manager (設計理念接近 &lt;a href=&#34;https://www.ghisler.com/&#34;&gt;Total Commander&lt;/a&gt;),  他可以調整的設定很多, 把他調得順手了, 順便做個紀錄.&lt;/p&gt;
&lt;h2 id=&#34;設定&#34;&gt;設定&lt;/h2&gt;
&lt;ol&gt;
&lt;li&gt;
&lt;p&gt;如何關閉下方 button panel&lt;/p&gt;
&lt;p&gt;按下 Ctrl-B 可開關&lt;/p&gt;
&lt;p&gt;Menu &amp;gt; Configuration &amp;gt; Core Settings, 然後參考 &lt;a href=&#34;http://multicommander.com/docs/buttonpanel&#34;&gt;這篇&lt;/a&gt;, 把 &lt;em&gt;Allow button panel to be undocked&lt;/em&gt; 打勾.
重開後就可以把 button panel 關掉了.&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;顯示 special folders&lt;/p&gt;
&lt;p&gt;Menu &amp;gt; Configuration &amp;gt; Explorer panel Settings -&amp;gt; Layout, 參考&lt;a href=&#34;http://multicommander.com/docs/drivebar&#34;&gt;這篇&lt;/a&gt;,&lt;/p&gt;
&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id=&#34;不順手的地方&#34;&gt;不順手的地方&lt;/h2&gt;
&lt;ol&gt;
&lt;li&gt;他的一般 toolbar 沒法自行加減 button, 只能修改 launch bar 上的 button. 但 launch bar 會是獨立的一列, 沒法和其他合併.&lt;/li&gt;
&lt;li&gt;他的 script 不容易 debug.&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id=&#34;和其他類似軟體的比較&#34;&gt;和其他類似軟體的比較&lt;/h2&gt;
&lt;p&gt;類似的軟體很多, 功能都有些許接近和重複, 挑喜歡的就好.&lt;/p&gt;
          
          
        
      </description>
    </item>
    
    <item>
      <title>使用 TWCC-CLI 從 TWCC 容器複本建立新的容器</title>
      <link>http://localhost:1313/tw/doc/software/twcc-twccli-duplicate-ccs/</link>
      <pubDate>Wed, 26 Oct 2022 18:18:32 +0800</pubDate>
      
      <guid>http://localhost:1313/tw/doc/software/twcc-twccli-duplicate-ccs/</guid>
      <description>
        
          
            &lt;h2 id=&#34;需求&#34;&gt;需求&lt;/h2&gt;
&lt;p&gt;已經有一個之前建好的 TWCC 容器複本, 要從這個複本建立一個新的容器, 操作完後並將他刪除&lt;/p&gt;
&lt;h2 id=&#34;前置作業-執行一次就好&#34;&gt;前置作業 (執行一次就好)&lt;/h2&gt;
&lt;ol&gt;
&lt;li&gt;
&lt;p&gt;設定環境變數&lt;/p&gt;
&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-sh&#34; data-lang=&#34;sh&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;1&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;$ &lt;span class=&#34;nb&#34;&gt;export&lt;/span&gt; &lt;span class=&#34;nv&#34;&gt;LANG&lt;/span&gt;&lt;span class=&#34;o&#34;&gt;=&lt;/span&gt;C.UTF-8
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;2&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;$ &lt;span class=&#34;nb&#34;&gt;export&lt;/span&gt; &lt;span class=&#34;nv&#34;&gt;LC_ALL&lt;/span&gt;&lt;span class=&#34;o&#34;&gt;=&lt;/span&gt;C.UTF-8
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;3&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;$ &lt;span class=&#34;nb&#34;&gt;export&lt;/span&gt; &lt;span class=&#34;nv&#34;&gt;PYTHONIOENCODING&lt;/span&gt;&lt;span class=&#34;o&#34;&gt;=&lt;/span&gt;UTF-8
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;登入TWCC&lt;/p&gt;
&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-sh&#34; data-lang=&#34;sh&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;1&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;$ twccli config init
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;檢查 TWCC CLI版本&lt;/p&gt;
&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-sh&#34; data-lang=&#34;sh&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;1&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;$ twccli config version
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;2&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;o&#34;&gt;[&lt;/span&gt;TWCCLI&lt;span class=&#34;o&#34;&gt;]&lt;/span&gt; This version is 0.5.24.2
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;如果你的版本不是 0.5.24.2, 請升級&lt;/p&gt;
&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-sh&#34; data-lang=&#34;sh&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;1&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;$ pip install -U TWCC-CLI
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;最後用這個指令看一下有哪些容器複本&lt;/p&gt;
&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-sh&#34; data-lang=&#34;sh&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;1&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;$ twccli ls ccs -img &lt;span class=&#34;s2&#34;&gt;&amp;#34;Custom Image&amp;#34;&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;2&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;Note : this operation take 1-2 mins
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;3&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;+ img ---------+------------------------------------------------+
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;4&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;p&#34;&gt;|&lt;/span&gt; sol_name     &lt;span class=&#34;p&#34;&gt;|&lt;/span&gt; images                                         &lt;span class=&#34;p&#34;&gt;|&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;5&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;+--------------+------------------------------------------------+
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;6&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;p&#34;&gt;|&lt;/span&gt; Custom Image &lt;span class=&#34;p&#34;&gt;|&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;[&lt;/span&gt;01&lt;span class=&#34;o&#34;&gt;]&lt;/span&gt; tensorflow-21.11-tf2-py3:test1            &lt;span class=&#34;p&#34;&gt;|&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;7&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;p&#34;&gt;|&lt;/span&gt;              &lt;span class=&#34;p&#34;&gt;|&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;[&lt;/span&gt;02&lt;span class=&#34;o&#34;&gt;]&lt;/span&gt; tensorflow-21.11-tf2-py3:test2            &lt;span class=&#34;p&#34;&gt;|&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;8&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;p&#34;&gt;|&lt;/span&gt;              &lt;span class=&#34;p&#34;&gt;|&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;[&lt;/span&gt;03&lt;span class=&#34;o&#34;&gt;]&lt;/span&gt; tensorflow-21.11-tf2-py3:test3            &lt;span class=&#34;p&#34;&gt;|&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;ln&#34;&gt;9&lt;/span&gt;&lt;span class=&#34;cl&#34;&gt;+--------------+------------------------------------------------+
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id=&#34;步驟&#34;&gt;步驟&lt;/h2&gt;
&lt;ol&gt;
&lt;li&gt;
&lt;p&gt;從之前建好的容器複本, 複製一個新容器. 最後面的 dup123 會是容器名稱&lt;/p&gt;
          
          
        
      </description>
    </item>
    
    <item>
      <title>檔案搜尋替代工具</title>
      <link>http://localhost:1313/tw/doc/software/file-search-and-replace-tool/</link>
      <pubDate>Sun, 23 Oct 2022 10:18:32 +0800</pubDate>
      
      <guid>http://localhost:1313/tw/doc/software/file-search-and-replace-tool/</guid>
      <description>
        
          
            &lt;h2 id=&#34;需求&#34;&gt;需求&lt;/h2&gt;
&lt;p&gt;要找一個可以在某個目錄下, 對檔案執行搜尋或替代文字的工具, 需支援以下功能:&lt;/p&gt;
&lt;ol&gt;
&lt;li&gt;免費軟體&lt;/li&gt;
&lt;li&gt;支援 UTF-8&lt;/li&gt;
&lt;li&gt;可在搜尋結果直接顯示部分內容 (不然沒有前後文的情況下, 一個一個點進去其實很花時間)&lt;/li&gt;
&lt;li&gt;Double click 搜尋結果就可以打開檔案編輯&lt;/li&gt;
&lt;li&gt;最好是能 replace&lt;/li&gt;
&lt;li&gt;愈快愈好 (廢話)&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id=&#34;軟體比較&#34;&gt;軟體比較&lt;/h2&gt;
&lt;p&gt;找了三個免費軟體來試試看, 目前看來是 grepWin 比較合用&lt;/p&gt;
&lt;ol&gt;
&lt;li&gt;&lt;a href=&#34;https://github.com/stefankueng/grepWin&#34;&gt;grepWin&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;http://www.nirsoft.net/utils/search_my_files.html&#34;&gt;SearchMyFiles&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;http://findandreplace.io/&#34;&gt;Find and Replace (FNR)&lt;/a&gt;&lt;/li&gt;
&lt;/ol&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;&lt;/th&gt;
					&lt;th&gt;grepWin&lt;/th&gt;
					&lt;th&gt;SearchMyFiles&lt;/th&gt;
					&lt;th&gt;Find and Replace (FNR)&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;GitHub star&lt;/td&gt;
					&lt;td&gt;1.3K&lt;/td&gt;
					&lt;td&gt;N/A&lt;/td&gt;
					&lt;td&gt;N/A&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;UTF-8&lt;/td&gt;
					&lt;td&gt;有&lt;/td&gt;
					&lt;td&gt;有 (*註1)&lt;/td&gt;
					&lt;td&gt;有&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;顯示檔案部分內容&lt;/td&gt;
					&lt;td&gt;有 (放在欄位)&lt;/td&gt;
					&lt;td&gt;有 (放在欄位)&lt;/td&gt;
					&lt;td&gt;有 (下方獨立 panel)&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Double click 開檔&lt;/td&gt;
					&lt;td&gt;有&lt;/td&gt;
					&lt;td&gt;有 (*註2)&lt;/td&gt;
					&lt;td&gt;有&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Replace&lt;/td&gt;
					&lt;td&gt;有&lt;/td&gt;
					&lt;td&gt;有&lt;/td&gt;
					&lt;td&gt;有&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;速度&lt;/td&gt;
					&lt;td&gt;快&lt;/td&gt;
					&lt;td&gt;快&lt;/td&gt;
					&lt;td&gt;稍慢&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;ul&gt;
&lt;li&gt;註1: SearchMyFiles 的 UTF-8 怪怪的, 如果輸入中文, 那他找得到, 也可以顯示. 但如果輸入英文, 他對於前後文的中文部分就會變成亂碼.&lt;/li&gt;
&lt;li&gt;註2: SearchMyFiles 預設 double click 會打開一個視窗顯示一些檔案資訊, 可透過 Options -&amp;gt; Double-Click 來改變行為.&lt;/li&gt;
&lt;/ul&gt;
          
          
        
      </description>
    </item>
    
    <item>
      <title>YouTube 各種加強工具</title>
      <link>http://localhost:1313/tw/doc/software/youtube-enhancer/</link>
      <pubDate>Wed, 31 Aug 2022 10:18:32 +0800</pubDate>
      
      <guid>http://localhost:1313/tw/doc/software/youtube-enhancer/</guid>
      <description>
        
          
            &lt;div class=&#34;notices warning&#34;&gt;
    &lt;div class=&#34;label&#34;&gt;注意&lt;/div&gt;
    &lt;p&gt;這些工具都不是 Google 官方提供, 有些我也沒用過, 執行前請先三思!!!&lt;/p&gt;

  &lt;/div&gt;

&lt;p&gt;整理一下 YouTube 在各平台上的各種加強工具.&lt;/p&gt;
&lt;h2 id=&#34;browser-extension-chrome-edge-&#34;&gt;Browser extension (Chrome, Edge, ...)&lt;/h2&gt;
&lt;ol&gt;
&lt;li&gt;
&lt;p&gt;&lt;a href=&#34;https://chrome.google.com/webstore/detail/enhancer-for-youtube/ponfpcnoihfmfllpaingbgckeeldkhle&#34;&gt;Enhancer for YouTube&lt;/a&gt;
這東西很好用, 但有個奇怪的點是, 他首頁強調的 &lt;strong&gt;當游標在播放器上時，使用滑鼠滾輪控制音量&lt;/strong&gt; (這功能真的很方便), 預設卻是關閉的, 要自己進去打開才會生效.&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;&lt;a href=&#34;https://chrome.google.com/webstore/detail/magic-actions-for-youtube/abjcfabbhafbcdfjoecdgepllmpfceif&#34;&gt;Magic Actions for YouTube&lt;/a&gt;
上次更新是 2021/5/2, 而且他有可能會拿走你的所有瀏覽紀錄 (參考: &lt;a href=&#34;https://robertheaton.com/2020/02/18/dont-let-magic-enhancer-for-youtube-slurp-up-your-browsing-history/&#34;&gt;https://robertheaton.com/2020/02/18/dont-let-magic-enhancer-for-youtube-slurp-up-your-browsing-history/&lt;/a&gt;)&lt;/p&gt;
&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id=&#34;用電腦下載-linux-macos-windows&#34;&gt;用電腦下載 (Linux, macOS, Windows)&lt;/h2&gt;
&lt;p&gt;YouTube 預設是不能讓人下載影片的 (即使是你自己上傳的影片也是一樣), 最有名的就是曾被 GitHub 下架的 &lt;a href=&#34;https://github.com/ytdl-org/youtube-dl&#34;&gt;youtube-dl&lt;/a&gt; 或是 &lt;a href=&#34;https://github.com/yt-dlp/yt-dlp&#34;&gt;ytl-dp&lt;/a&gt;. 使用起來很簡單, 可參考: &lt;a href=&#34;https://dennys.github.io/tw/doc/software/download-youtube-private-video/&#34;&gt;https://dennys.github.io/tw/doc/software/download-youtube-private-video/&lt;/a&gt;&lt;/p&gt;
&lt;h2 id=&#34;android&#34;&gt;Android&lt;/h2&gt;
&lt;p&gt;最有名的 &lt;a href=&#34;https://vancedapp.com/&#34;&gt;Vanced&lt;/a&gt; 已經在 2022 年 3 月下架了, 有一堆替代品, 不過看來很多都是基於&lt;a href=&#34;https://github.com/TeamNewPipe/NewPipeExtractor&#34;&gt;NewPipe Extractor&lt;/a&gt;.
試玩了幾個, 每個人的需求不同, 對我來講比較有感的是這幾個功能:&lt;/p&gt;
&lt;ol&gt;
&lt;li&gt;官方 YouTube 的全螢幕模式我用不太習慣, 我是比較喜歡按下全螢幕就直接轉成橫向放大.&lt;/li&gt;
&lt;li&gt;手勢, 尤其前後快轉真的好用.&lt;/li&gt;
&lt;li&gt;下載的時候能自動合併影音, 這還滿方便的, 不然還得另外合併, 而且是在手機上, 會很麻煩.&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;https://store.google.com/tw/product/chromecast&#34;&gt;Chromecast&lt;/a&gt;, 這個雖然不常用, 但要投影到電視的時候就很方便... 不過現在應該也都直接用 Google TV 了, 好像想不太出應用場合.&lt;/li&gt;
&lt;/ol&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;&lt;/th&gt;
					&lt;th&gt;NewPipe&lt;/th&gt;
					&lt;th&gt;SkyTube&lt;/th&gt;
					&lt;th&gt;LibreTube&lt;/th&gt;
					&lt;th&gt;VueTube&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;GitHub star&lt;/td&gt;
					&lt;td&gt;20.7K&lt;/td&gt;
					&lt;td&gt;1.7K&lt;/td&gt;
					&lt;td&gt;2.8k&lt;/td&gt;
					&lt;td&gt;2.2k&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Extractor&lt;/td&gt;
					&lt;td&gt;NewPipe Extractor&lt;/td&gt;
					&lt;td&gt;NewPipe Extractor&lt;/td&gt;
					&lt;td&gt;NewPipe Extractor&lt;/td&gt;
					&lt;td&gt;VueTube-Extractor&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;外部撥放器&lt;/td&gt;
					&lt;td&gt;支援&lt;/td&gt;
					&lt;td&gt;支援&lt;/td&gt;
					&lt;td&gt;---&lt;/td&gt;
					&lt;td&gt;---&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;帳號登入&lt;/td&gt;
					&lt;td&gt;無 (設計理念)&lt;/td&gt;
					&lt;td&gt;無&lt;/td&gt;
					&lt;td&gt;LibraTube 帳號&lt;/td&gt;
					&lt;td&gt;Google (計畫中)&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;訂閱清單匯入&lt;/td&gt;
					&lt;td&gt;有 (支援 zip)&lt;/td&gt;
					&lt;td&gt;只收 json, 得轉檔&lt;/td&gt;
					&lt;td&gt;有(未測試)&lt;/td&gt;
					&lt;td&gt;好像沒有?&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;下載影片&lt;/td&gt;
					&lt;td&gt;有 (影音分開)&lt;/td&gt;
					&lt;td&gt;有(影音&lt;strong&gt;合併&lt;/strong&gt;)&lt;/td&gt;
					&lt;td&gt;有(影音&lt;strong&gt;合併&lt;/strong&gt;)&lt;/td&gt;
					&lt;td&gt;無&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;手勢&lt;/td&gt;
					&lt;td&gt;音量/亮度&lt;/td&gt;
					&lt;td&gt;音量/亮度/&lt;strong&gt;前進後退&lt;/strong&gt;&lt;/td&gt;
					&lt;td&gt;無&lt;/td&gt;
					&lt;td&gt;無&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Chromecast&lt;/td&gt;
					&lt;td&gt;無&lt;/td&gt;
					&lt;td&gt;Extra 版才有 &lt;br/&gt; (non-opensource)&lt;/td&gt;
					&lt;td&gt;無&lt;/td&gt;
					&lt;td&gt;無&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
